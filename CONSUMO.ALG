Algoritmo "consumo"


Var
    distancia: inteiro
    combustivel: real
    consumo: real

Inicio

      escreva ("Distancia percorrida: ")
      leia(distancia)
      escreva ("Combustiivel gasto: ")
      leia (combustivel)
      
      consumo <- distancia / combustivel
      
       escreval ("Consumo medio = ", consumo:5:3)

Fimalgoritmo